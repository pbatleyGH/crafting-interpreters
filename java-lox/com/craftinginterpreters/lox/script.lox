class SuperClass {
    scramble_name() {}
}

class Person < SuperClass {
    class greet() {
        print "Hello!";
    }

    init(firstname, surname) {
        this.firstname = firstname;
        this.surname = surname;
    }

    print_name() {
        print this.firstname + " " + this.surname;
    }
}

Person.greet();

var pete = Person("Pete", "Batley");
pete.print_name();

print Person.scramble_name();