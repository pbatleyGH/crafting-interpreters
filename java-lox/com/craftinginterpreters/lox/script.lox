class Test {
    class greet() {
        print "Hello!";
    }

    class staticSelf() {
        return this;
    }

    class init() {
        print "Static init method called.";
    }

    init(name) {
        this.name = name;
    }

    self() {
        return this;
    }
}

print Test.staticSelf();
print Test("Pete").self();